<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Singleton User -->
    <bean id="myUser"
          class="com.codingNinjas.Bank.Account.Registration.myUser"
          init-method="init"
          destroy-method="destroy"/>

    <!-- Prototype Accounts -->
    <bean id="currentAccount"
          class="com.codingNinjas.Bank.Account.Registration.currentAccount"
          scope="prototype"
          init-method="init"/>

    <bean id="savingsAccount"
          class="com.codingNinjas.Bank.Account.Registration.savingsAccount"
          scope="prototype"
          init-method="init"/>

</beans>